# SFTP-Zugangsdaten fuer build_and_deploy.ps1
# Datei kopieren: copy .env.example .env
# Dann .env mit echten Zugangsdaten befuellen (wird NICHT in Git eingecheckt)

SFTP_HOST=sftp.example.com
SFTP_USER=mein_sftp_benutzer
SFTP_PATH=/pfad/auf/dem/server

# Optional: Lokales Zielverzeichnis (Standard: releases\)
# LOCAL_RELEASES_DIR=releases

# Optional: ESP-IDF venv-Pfad ueberschreiben falls falsche Python-Version erkannt wird
# IDF_PYTHON_ENV_PATH=C:\Users\bonta\.espressif\python_env\idf5.5_py3.11_env
